# Supabase Configuration
PUBLIC_SUPABASE_URL=your-supabase-url
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Admin secret key (only for server-side)
SUPABASE_ADMIN_KEY=your-supabase-admin-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Brevo Configuration (Email Service)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-email@example.com
BREVO_FROM_NAME=Your Company Name

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Cron Protection
CRON_SECRET=your-cron-secret

# Site URL (used in astro.config and emails)
SITE_URL=http://localhost:4321