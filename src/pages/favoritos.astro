---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Mis Favoritos - Joyería Galiana">
  <link rel="stylesheet" href="/css/favoritos.css?v=3" />

  <section class="favoritos-page">
    <div class="favoritos-container">
      <div class="favoritos-header">
        <h1>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="var(--color-principal)" stroke="var(--color-principal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          Mis Favoritos
        </h1>
        <p class="favoritos-subtitle" id="favoritos-subtitle">Tus piezas favoritas en un solo lugar</p>
      </div>

      <!-- Estado: No logueado -->
      <div id="favoritos-no-auth" class="favoritos-estado" style="display:none;">
        <div class="favoritos-empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-principal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5;">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
        <h3>Inicia sesión para ver tus favoritos</h3>
        <p>Guarda tus joyas favoritas y accede a ellas desde cualquier dispositivo.</p>
        <a href="/cuenta" class="favoritos-btn-primary">Iniciar Sesión</a>
      </div>

      <!-- Estado: Cargando -->
      <div id="favoritos-loading" class="favoritos-estado" style="display:none;">
        <div class="favoritos-spinner"></div>
        <p>Cargando tus favoritos...</p>
      </div>

      <!-- Estado: Sin favoritos -->
      <div id="favoritos-empty" class="favoritos-estado" style="display:none;">
        <div class="favoritos-empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-principal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5;">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
        <h3>Aún no tienes favoritos</h3>
        <p>Explora nuestra colección y marca las joyas que más te gusten.</p>
        <a href="/joyeria" class="favoritos-btn-primary">Explorar Joyería</a>
      </div>

      <!-- Grid de productos favoritos -->
      <div id="favoritos-grid" class="favoritos-grid" style="display:none;"></div>
    </div>
  </section>

  <script src="/js/favoritos-page.js?v=3" defer is:inline></script>
</PublicLayout>
